# Test method calls inside functions

method test_range(n: int) -> list<int> {
    spawn result: list<int> = []
    spawn i: int = 0
    
    while i < n {
        result.append(i)
        i = i + 1
    }
    
    release result
}

spawn numbers: list<int> = test_range(5)
echo("Numbers: {ret(numbers)}")
